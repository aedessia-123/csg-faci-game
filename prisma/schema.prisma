generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// Shared taxonomy of what a scenario option can score against.
// Small, stable, rarely edited by the admin.
model Competency {
  id         String   @id @default(cuid())
  key        String   @unique // e.g. "execution_discipline" - stable identifier used by the scoring engine
  name       String
  icon       String
  definition String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  scenariosAsA Scenario[] @relation("ScenarioCompetencyA")
  scenariosAsB Scenario[] @relation("ScenarioCompetencyB")
}

// A readiness tier (L0, L1, L2...). Holds the copy and pass rule for that tier.
model Level {
  id            String   @id @default(cuid())
  key           String   @unique // "L0"
  name          String
  tagline       String
  intro         String
  threshold     Int      @default(12)
  nextLevelName String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  games Game[]
}

enum ScenarioStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

// The content bank. Scenarios are authored once and reused across many games.
// Every scenario tests exactly 2 competencies (A and B) - a fixed-arity design
// choice, not a limitation, so it's modeled directly rather than via a join table.
model Scenario {
  id               String         @id @default(cuid())
  title            String
  prompt           String
  occasion         String? // free-tag e.g. "onboarding", "refresher", "conflict-focus"
  difficulty       String? // "easy" | "medium" | "hard"
  suggestedLevelId String?
  status           ScenarioStatus @default(DRAFT)
  competencyAId    String
  competencyA      Competency     @relation("ScenarioCompetencyA", fields: [competencyAId], references: [id])
  competencyBId    String
  competencyB      Competency     @relation("ScenarioCompetencyB", fields: [competencyBId], references: [id])
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  options   ScenarioOption[]
  gameLinks GameScenario[]
}

// Exactly 4 per scenario by convention (enforced in the admin UI, not the DB).
// scoreA/whyA score+explain against the scenario's competencyA, scoreB/whyB against competencyB.
model ScenarioOption {
  id          String   @id @default(cuid())
  scenarioId  String
  scenario    Scenario @relation(fields: [scenarioId], references: [id], onDelete: Cascade)
  text        String
  order       Int // author-defined order in the editor; runtime shuffles display order separately
  scoreA      Int // 1-4 against the scenario's competencyA
  whyA        String
  scoreB      Int // 1-4 against the scenario's competencyB
  whyB        String
  isRedFlag   Boolean  @default(false)
  redFlagNote String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

enum GameStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

// A named, publishable bundle: a Level + Occasion + a curated set of Scenarios.
// This is what the admin assembles and what the player fetches at runtime.
model Game {
  id        String     @id @default(cuid())
  slug      String     @unique
  name      String
  levelId   String
  level     Level      @relation(fields: [levelId], references: [id])
  occasion  String?
  status    GameStatus @default(DRAFT)
  version   Int        @default(1)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  scenarios GameScenario[]
  sessions  GameSession[]
}

model GameScenario {
  id         String   @id @default(cuid())
  gameId     String
  game       Game     @relation(fields: [gameId], references: [id], onDelete: Cascade)
  scenarioId String
  scenario   Scenario @relation(fields: [scenarioId], references: [id])
  order      Int

  @@unique([gameId, scenarioId])
}

// One row per completed (or in-progress) play-through, for basic curation analytics.
model GameSession {
  id          String    @id @default(cuid())
  gameId      String
  game        Game      @relation(fields: [gameId], references: [id])
  startedAt   DateTime  @default(now())
  completedAt DateTime?
  totalScore  Float?
  cleared     Boolean?
  answers     Json? // [{ scenarioId, optionId }] - raw log for admin analytics
}
